{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(sudo rm*)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(*.env)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(pkill *)",
      "Bash(kill *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": "echo 'Claude finished'"
      }
    ]
  }
}